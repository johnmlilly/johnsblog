---
title: Freelance Web Developer in Northern VA
layout: base.njk
image: /assets/logo/Social-Media-Cover.png
description: Full stack freelance web developer in Northern Virginia helping
  nonprofits and Catholic businesses build modern, mission-driven websites that
  inspire action.
---

<!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-content">
          <h1>{{ home.hero.name }}</h1>
          <h2>{{ home.hero.greeting }}</h2>
          <p>{{ home.hero.description }}</p>
          <p>I help <strong><span id="hero-text"></span></strong> create websites that work — and look — great.</p>
          <div class="hero-buttons">
            <a href="{{ home.hero.firstCtaUrl }}" class="btn btn-primary">{{ home.hero.firstCtaText }}</a>
            <a href="{{ home.hero.secondCtaUrl }}" class="btn btn-outline">{{ home.hero.secondCtaText }}</a>
          </div>
        </div>
        <div class="hero-image">
          <div class="profile-image-container">
            <img loading="eager" fetchpriority="high" src="{{ home.hero.image }}" alt="John Lilly" class="profile-image">
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- About Me Section -->
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <img src="{{ home.about.image }}" alt="John Lilly">
        </div>
        <div class="about-content">
          <h2>{{ home.about.heading }}</h2>
          <div class="about-text">
            {% for p in home.about.description %}
              <p>{{ p }}</p>
            {% endfor %}
          </div>
          <div>
            <a href="{{ home.about.ctaUrl }}" class="btn btn-primary">{{ home.about.ctaText }}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

<!-- Services Section -->
 <section id="services">
  <div class="container">
    <h2>{{ home.services.title }}</h2>
    <p>{{ home.services.subtitle }}</p>

    <div class="services-grid">
      {% for card in home.services.cards %}
        <div class="services-card">
          <div class="services-header">
            <i data-lucide="{{ card.icon }}"></i>
            <h3>{{ card.title }}</h3>
          </div>
          <p>{{ card.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>


  <!-- Projects Section -->
  <section id="projects" class="alternate-section">
    <div class="container">
      <div class="section-header">
         <h2>Projects</h2>
        <a href="/projects">View All </a>
      </div>
      <div class="projects-grid">
        {%- for project in collections.featuredProjects -%}
          {% include 'projects-snippet.njk' %}
        {%- endfor -%}
      </div>
    </div>
  </section>

<!-- Blog Section -->
  <section id="blog" class="blog-section">
    <div class="container">
      <div class="section-header">
        <h2>Blog</h2>
        <a href="/blog">View All </a>
      </div>
      <div class="blog-grid">
        {%- for post in collections.featuredBlog -%}
          {% include 'article-snippet.njk' %}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="alternate-section">
    <div class="container">
      <h2>Skills & Expertise</h2>
        <div class="skills-grid">
          {% for skill in collections.skills %}
            {% include 'skills-snippet.njk' %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="contact-cta-section">
    <div class="container">
      <div class="contact-cta-content">
        <h2>{{ home.contact.heading }}</h2>
        <p>{{ home.contact.description }}</p>
        <a href="/contact" class="btn btn-primary btn-lg">{{ home.contact.cta }}</a>
      </div>
    </div>
  </section>
